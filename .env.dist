
###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_DEBUG=0
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
